{
  "name": "greenmind-ai-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "GreenMind AI - AI-powered Sustainable Lifestyle Assistant",
  "author": "Laxmi Choudhary",
  "license": "MIT",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",

    "lint": "eslint . --ext js,jsx --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",

    "format": "prettier --write .",

    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage"
  },

  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",

    "react-router-dom": "^7.18.0",

    "lucide-react": "^1.21.0",

    "recharts": "^3.8.1",

    "react-error-boundary": "^6.0.0"
  },

  "devDependencies": {
    "vite": "^8.0.12",
    "@vitejs/plugin-react": "^6.0.1",

    "eslint": "^10.3.0",
    "@eslint/js": "^10.0.1",
    "globals": "^17.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",

    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",

    "tailwindcss": "^3.4.0",
    "postcss": "^8.5.15",
    "autoprefixer": "^10.5.0",

    "prettier": "^3.6.2",

    "vitest": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^27.0.0"
  }
